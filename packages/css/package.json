    "./styles": "./styles/*"
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "dependencies": {
    "lightningcss": "1.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest"
  }
}
